Env.Var.wlan_keytype.Value.ascii = ASCII
Env.Var.wlan_keytype.Value.hexa = Hexadecimal
Env.Var.wlan_keytype.Error.value = Invalid format

Env.Var.wlan_wepkey.Header = Key
Env.Var.wlan_wepkey.Error.ascii = Key must be 5 or 13 characters exactly, and must not contain " ' `.
Env.Var.wlan_wepkey.Error.hexa = Key must be 10 or 26 characters exactly, and contain only hexadecimal characters.

Env.Var.wlan_wpaenctype.Header = Key type
Env.Var.wlan_wpaenctype.Value.tkip = TKIP
Env.Var.wlan_wpaenctype.Value.aes = AES
Env.Var.wlan_wpaenctype.Value.tkipaes = TKIP et AES

Env.Var.wlan_wpakey.Header = Key
Env.Var.wlan_wpakey.Error.value = The key length must be between 8 and 63 characters inclusive, and must not contain " ' `.

Env.Form.Error.wpa_aes_incompatibility = Some wireless devices are not compatible with the encryption system 'WPA Personal (PSK)' and the key type 'AES'.

Env.Form.Error.enc_mode_incompatibility = The selected encryption system is not compatible with the radion mode currently in use. Please change the radio mode on the "Settings" page before selecting another encryption sytem.

