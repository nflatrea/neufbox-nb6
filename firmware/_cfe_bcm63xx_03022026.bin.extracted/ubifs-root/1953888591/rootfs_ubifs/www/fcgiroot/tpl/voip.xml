<rsp stat="ok">
  <voip>
    <linestatus val="<?cs var:Var.voip_linestatus.Value?>" text="<?cs if:Var.voip_linestatus.Value == "down" && Env.user.eco.voip.active == "off" && Env.status.eco.status=="up" ?>
                                                                <?cs call:varValue_d(Env.Var.voip_linestatus.Value.down_eco, Env.Var.voip_linestatus.Value.down)?>
                                                            <?cs else ?>
                                                                <?cs call:varValue_d(Env.Var.voip_linestatus.Value[Var.voip_linestatus.Value], Env.Var.voip_linestatus.Value.down)?>
                                                            <?cs /if ?>" />
    <hookstatus val="<?cs var:Var.voip_hookstatus.Value?>" text="<?cs call:varValue_d(Env.Var.voip_hookstatus.Value[Var.voip_hookstatus.Value], Env.Var.voip_hookstatus.Value.unknown)?>" />
    <access val="<?cs var:Var.voip_access.Value?>" text="<?cs call:varValue(Env.Var.voip_access.Value[Var.voip_access.Value])?>" />
    <history val="<?cs if:Env.user.voip.callhistory == "off"?>disabled<?cs else ?>enabled<?cs /if ?>" text="<?cs call:varValue(Env.Var.callhistory_active.Value[Env.user.voip.callhistory])?>" />
    <missedcall val="<?cs if:Env.user.voip.usermissedcall == "off" ?>disabled<?cs else ?>enabled<?cs /if ?>" text="<?cs call:varValue(Env.Var.led_notification_active.Value[Env.user.voip.usermissedcall])?>" />
    <?cs if:?Env.autoconf.voip.sig && Env.autoconf.voip.sig=="sip" ?>
    <blacklist val="<?cs if:Env.user.voip.blacklist.active  == "off" ?>disabled<?cs else ?>enabled<?cs /if ?>" text="<?cs if:Env.user.voip.blacklist.active  == "off" ?><?cs var:Env.Text.Disabled ?><?cs else ?><?cs var:Env.Text.Enabled ?><?cs /if ?>" />
    <?cs /if ?>
  </voip>
</rsp>
