<?xml version="1.0" encoding="UTF-8"?>
<rsp stat="ok">
  <internet>
    <link val="<?cs var:Env.status.net.status?>" text="<?cs call:varValue_d(Env.Var.internet_status.Value[Env.status.net.status], Env.Var.internet_status.Value.down)?>" />
    <access val="<?cs var:Env.status.net.data.access?>" text="<?cs call:varValue(Env.Var.internet_access.Value[Env.status.net.data.access])?>" />
    <uptime val="<?cs var:Var.wan_uptime.day.Value ?> <?cs var:Env.Text.dayAbbr?> <?cs var:Var.wan_uptime.hour.Value ?> <?cs var:Env.Text.hourAbbr?> <?cs var:Var.wan_uptime.min.Value ?> <?cs var:Env.Text.minAbbr?> <?cs var:Var.wan_uptime.sec.Value ?> <?cs var:Env.Text.secAbbr?>" />
  </internet>
  <voip>
    <link val="<?cs var:Env.status.voip.up ?>" text="<?cs call:varValue_d(Env.Var.voip_status.Value[Env.status.voip.up], Env.Var.voip_status.Value.down)?>" />
    <access val="<?cs var:Env.status.net.voip.access?>" text="<?cs call:varValue(Env.Var.voip_access.Value[Env.status.net.voip.access])?>" />
  </voip>
  <wifi>
    <link val="<?cs var:Var.wifi_status.Value ?>" />
    <linkac val="<?cs var:Var.wifi_status_ac.Value ?>" />
  </wifi>
  <tv>
      <?cs set:tv_status="up"?>
      <?cs if:Var.tv_status.Value == "0" ?><?cs set:tv_status="down"?><?cs /if ?>
    <link val="<?cs var:tv_status ?>" text="<?cs call:varValue_d(Env.Var.tv_status.Value[tv_status], Env.Var.tv_status.Value.down)?>" />
  </tv>
  <system>
    <uptime val="<?cs var:Var.modem_uptime.day.Value ?> <?cs var:Env.Text.dayAbbr?> <?cs var:Var.modem_uptime.hour.Value ?> <?cs var:Env.Text.hourAbbr?> <?cs var:Var.modem_uptime.min.Value ?> <?cs var:Env.Text.minAbbr?> <?cs var:Var.modem_uptime.sec.Value ?> <?cs var:Env.Text.secAbbr?>" />
  </system>
  <gruiks>
    <?cs each:item = Var.gruiks ?><gruik><?cs var:item.Value ?></gruik><?cs /each ?>
  </gruiks>
  <loop_detection>
    <loop_interface val="<?cs var:Var.loop_interface.Value?>" />
  </loop_detection>
</rsp>
