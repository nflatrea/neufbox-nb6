<?cs def:lanIfaceToPortName(iface)?><?cs if:iface == "lan0" ?>Fibre<?cs elif:iface == "lan1" ?>LAN 1<?cs elif:iface == "lan2" ?>LAN 2<?cs elif:iface == "lan3" ?>LAN 3<?cs elif:iface == "lan4" ?>LAN 4<?cs elif:iface == "lan5" ?>Interne<?cs elif:iface == "ftth" ?>FIBRE<?cs elif:iface == "femto" ?>Femtocell<?cs else ?>Inconnu<?cs /if ?><?cs /def?><?cs def:varIf(varname) ?><?cs if:?varname ?><?cs var:varname ?><?cs /if ?><?cs /def ?><?cs def:varIf_d(varname, default) ?><?cs if:?varname ?><?cs var:varname ?><?cs else ?><?cs var:default ?><?cs /if ?><?cs /def ?><?cs def:IfaceToPortName(iface)?><?cs if:iface == "usb"?>USB PC<?cs elif:iface == "wl0"?>Wifi 5GHz<?cs elif:iface == "wl1"?>Wifi 2.4GHz<?cs elif:iface == "guest"?>Wifi Guest<?cs else?><?cs call:lanIfaceToPortName(iface)?><?cs /if?><?cs /def?><?cs def:sectionTitle(name)?><?cs alt:Env.Section[name].Title?>Section <?cs var:name?><?cs /alt?><?cs /def?><?cs def:varHeader(name)?><?cs alt:Env.Var[name].Header?><?cs var:value?><?cs /alt?><?cs /def?><?cs def:_varErrorDiv(name, error, defaulterror)?><?cs if:?Var[name].Error?><div class="help-inline"><?cs alt:Env.Var[name].Error[error]?><?cs var:defaulterror?><?cs /alt?></div><?cs /if?><?cs /def?><?cs def:varErrorDiv(name)?><?cs call:_varErrorDiv(name, Var[name].Error, Env.Text.UnknownError)?><?cs /def?><?cs def:varErrorDiv_d(name, defaultErrorName)?><?cs call:_varErrorDiv(name, Var[name].Error, Env.Var[name].Error[defautErrorName])?><?cs /def?><?cs def:varErrorDiv_gd(name, defaultErrorValue)?><?cs call:_varErrorDiv(name, Var[name].Error, defaultErrorValue)?><?cs /def?><?cs def:varValue(name)?> <?cs alt:name?><?cs var:Env.Text.UnknownValue ?><?cs /alt ?><?cs /def?><?cs def:varValue_d(name, defaultvalue)?><?cs if:?name?><?cs var:name?><?cs else?><?cs alt:defaultvalue?><?cs var:Env.Text.UnknownValue ?><?cs /alt ?><?cs /if?><?cs /def?><?cs def:div_onoff(name,value) ?><div class="form-group btn-onoff"><label for="<?cs var:name ?>_on" class="inline radio"><input type="radio" name="<?cs var:name ?>" id="<?cs var:name ?>_on" value="on" toggle-switch-data="on" <?cs if:value ?>checked="checked"<?cs /if ?>/><?cs var:Env.Text.Enabled ?></label><label for="<?cs var:name ?>_off" class="inline radio"><input type="radio" name="<?cs var:name ?>" id="<?cs var:name ?>_off" value="off" toggle-switch-data="off" <?cs if:!value ?>checked="checked"<?cs /if ?> /><?cs var:Env.Text.Disabled ?></label></div><?cs /def ?><?cs def:replace(str,search,replace) ?><?cs set:pos=string.find(str, search) ?><?cs if:pos!=-1 ?><?cs set:part1=string.slice(str, 0, pos) ?><?cs set:part2=string.slice(str, pos+string.length(search), string.length(str)) ?><?cs call:replace(part1 + replace + part2,search,replace)?><?cs else ?><?cs var:str ?><?cs /if ?><?cs /def ?>